{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "axm-toolkit",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-c", "import os,http.server,socketserver; port=int(os.environ.get('PORT','8777')); socketserver.TCPServer(('',port), http.server.SimpleHTTPRequestHandler).serve_forever()"],
      "port": 8777,
      "autoPort": true
    }
  ]
}
